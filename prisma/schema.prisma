generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Core Tables ─────────────────────────────────────────────────────────────

model User {
  id        String   @id // Supabase auth UUID — no auto-generate
  email     String   @unique
  name      String
  role      String   @default("MEMBER") // MEMBER | MENTOR | ADMIN | CURRICULUM_LEAD | PROJECT_LEAD
  cohort    String?  // [FUTURE] e.g. "Spring 2026"
  mentorId  String?  // [FUTURE] self-referential FK
  activeTrackId String? // currently-selected track (also mirrored to a cookie for SSR)
  createdAt DateTime @default(now())

  mentor    User?  @relation("MentorRecruits", fields: [mentorId], references: [id])
  recruits  User[] @relation("MentorRecruits")

  bookmarks              Bookmark[]
  suggestedResources     Resource[]
  quizAttempts           QuizAttempt[]
  homeworkSubmissions    HomeworkSubmission[]
  mentorNotesGiven       MentorNote[]          @relation("MentorNoteGiver")
  mentorNotesReceived    MentorNote[]          @relation("MentorNoteRecruit")
  projectAssignments     ProjectAssignment[]
  createdAssignments     Assignment[]          @relation("AssignmentCreator")
  createdFormalQuizzes   FormalQuiz[]          @relation("FormalQuizCreator")
  formalQuizAttempts     FormalQuizAttempt[]
  feedbackSubmitted      Feedback[]
  teamMemberships        TeamMembership[]
  teamDrops              TeamDrop[]
  teamDropReactions      TeamDropReaction[]
  createdProjects        Project[]             @relation("ProjectCreator")
  projectInterests       ProjectInterest[]

  @@map("users")
}

// ─── Tracks (top-level content domain: AI / Capital Markets / Field Guides) ──
// New root above Tier. Tier is the only model that needs the FK — Section /
// Concept / Question / Bookmark inherit a Track transitively through Tier.

model Track {
  id          String  @id @default(cuid())
  slug        String  @unique // "ai" | "capital-markets" | "field-guides"
  name        String
  shortName   String
  description String
  accentColor String  // per-track accent swatch
  isPrimary   Boolean @default(false) // AI = true
  sortOrder   Int

  tiers       Tier[]
  projects    Project[]

  @@map("tracks")
}

// ─── Team HQ ─────────────────────────────────────────────────────────────────
// Membership keys on TEAM SLUG (validated against the code registry in lib/teams.ts),
// not track id, because content-less teams (Media) have rosters too. No FK: teams
// live in code. This redefines the dormant, empty TrackMembership table.

model TeamMembership {
  userId   String
  teamSlug String // validated against the registry in app code; no FK (teams live in code)
  joinedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@id([userId, teamSlug])
  @@map("team_memberships")
}

// The Drop: a team bulletin. Members post a link from the team's world with a
// one-line take. The "good find" count is reactions.length per drop and is NEVER
// aggregated across a user (no per-person score, no top-contributor view).

model TeamDrop {
  id           String    @id @default(cuid())
  teamSlug     String // validated against the registry
  userId       String
  url          String
  title        String // headline; pasted in v1 (OG auto-fetch is a later nicety)
  sourceDomain String
  note         String // the required one-line take
  conceptSlug  String? // optional soft link to the curriculum
  trendSlug    String? // optional soft link to a trend
  createdAt    DateTime  @default(now())
  removedAt    DateTime? // lead soft-remove; no hard delete

  user      User               @relation(fields: [userId], references: [id])
  reactions TeamDropReaction[]

  @@index([teamSlug, createdAt])
  @@map("team_drops")
}

model TeamDropReaction {
  dropId String
  userId String

  drop TeamDrop @relation(fields: [dropId], references: [id], onDelete: Cascade)
  user User     @relation(fields: [userId], references: [id])

  @@id([dropId, userId])
  @@map("team_drop_reactions")
}

model Tier {
  id          String    @id @default(cuid())
  trackId     String?   // nullable for safe migration; backfilled to the "ai" track
  name        String
  slug        String    @unique
  description String
  sortOrder   Int
  color       String

  track       Track?    @relation(fields: [trackId], references: [id])
  sections    Section[]

  @@index([trackId])
  @@map("tiers")
}

model Section {
  id          String    @id @default(cuid())
  tierId      String
  name        String
  slug        String    @unique
  description String
  sortOrder   Int

  tier        Tier      @relation(fields: [tierId], references: [id])
  concepts    Concept[]

  @@map("sections")
}

model Concept {
  id           String   @id @default(cuid())
  sectionId    String
  name         String
  slug         String   @unique
  subtitle     String
  difficulty   String   // FUNDAMENTALS | INTERMEDIATE | ADVANCED
  whatItIs             String
  simpleExplanation    String?
  flashcardShort       String?
  flashcardDefinition  String?
  whyItMatters         String
  goDeeper             String?
  sortOrder    Int

  section      Section           @relation(fields: [sectionId], references: [id])
  questions    Question[]
  resources    Resource[]
  bookmarks    Bookmark[]
  assignments  Assignment[]
  relatedFrom  ConceptRelation[] @relation("ConceptFrom")
  relatedTo    ConceptRelation[] @relation("ConceptTo")

  @@map("concepts")
}

model ConceptRelation {
  conceptId        String
  relatedConceptId String

  concept        Concept @relation("ConceptFrom", fields: [conceptId], references: [id])
  relatedConcept Concept @relation("ConceptTo", fields: [relatedConceptId], references: [id])

  @@id([conceptId, relatedConceptId])
  @@map("concept_relations")
}

model Resource {
  id               String  @id @default(cuid())
  conceptId        String
  title            String
  url              String
  sourceDomain     String
  type             String  // VIDEO | ARTICLE | PAPER | TUTORIAL
  estimatedMinutes Int?
  description      String?
  sortOrder        Int
  suggestedById    String? // [FUTURE]

  concept     Concept @relation(fields: [conceptId], references: [id])
  suggestedBy User?   @relation(fields: [suggestedById], references: [id])

  @@map("resources")
}

model Question {
  id                String  @id @default(cuid())
  conceptId         String
  type              String  // MC | SHORT_ANSWER
  questionText      String
  options           String? // JSON array [{text, isCorrect}] — null for SHORT_ANSWER
  answerExplanation String
  difficulty        String  // FUNDAMENTALS | INTERMEDIATE | ADVANCED

  concept             Concept              @relation(fields: [conceptId], references: [id])
  attempts            QuizAttempt[]
  formalQuizQuestions  FormalQuizQuestion[]
  formalQuizAnswers   FormalQuizAnswer[]

  @@map("questions")
}

model Bookmark {
  userId    String
  conceptId String
  status    String   @default("bookmarked") // [FUTURE]: in_progress | confident
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  concept Concept @relation(fields: [conceptId], references: [id])

  @@id([userId, conceptId])
  @@map("bookmarks")
}

// ─── Future Tables (schema only — no MVP UI/routes built) ────────────────────

model QuizAttempt {
  id             String   @id @default(cuid())
  userId         String
  questionId     String
  selectedAnswer String?
  isCorrect      Boolean?
  attemptedAt    DateTime @default(now())
  llmScore       String?  // "correct" | "partial" | "incorrect" — null for MC
  llmReasoning   String?  // LLM explanation of grade
  llmGradedAt    DateTime?

  user     User     @relation(fields: [userId], references: [id])
  question Question @relation(fields: [questionId], references: [id])

  @@map("quiz_attempts")
}

model HomeworkSubmission {
  id           String   @id @default(cuid())
  userId       String
  assignmentId String
  content      String
  submittedAt  DateTime @default(now())
  grade        String?  // e.g. "A", "B+", "Pass", "Fail"
  feedback     String?
  gradedAt     DateTime?

  user       User       @relation(fields: [userId], references: [id])
  assignment Assignment @relation(fields: [assignmentId], references: [id])

  @@unique([userId, assignmentId]) // One submission per recruit per assignment
  @@map("homework_submissions")
}

model MentorNote {
  id        String   @id @default(cuid())
  mentorId  String
  recruitId String
  note      String
  createdAt DateTime @default(now())

  mentor  User @relation("MentorNoteGiver", fields: [mentorId], references: [id])
  recruit User @relation("MentorNoteRecruit", fields: [recruitId], references: [id])

  @@map("mentor_notes")
}

model ProjectAssignment {
  id         String   @id @default(cuid())
  userId     String
  projectId  String
  role       String   // e.g. "Lead" | "Contributor" — display string on the team list
  assignedAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  project Project @relation(fields: [projectId], references: [id])

  @@unique([userId, projectId])
  @@index([projectId])
  @@map("project_assignments")
}

// ─── Build Board (member projects showcase) ─────────────────────────────────
// Showcase-only MVP: admin-seeded projects behind a draft → approved gate.
// Members (and logged-out visitors) only ever see approved rows.

model Project {
  id                String    @id @default(cuid())
  slug              String    @unique
  title             String
  blurb             String    // one or two sentences shown on the card
  description       String?   // Markdown body for the detail page
  status            String    @default("draft") // draft | approved
  stage             String    @default("building") // idea | building | shipped | paused
  trackId           String?   // drives the card's IconTile color
  lookingFor        Json?     // string[] of open-role tags, e.g. ["designer"]
  repoUrl           String?
  demoUrl           String?
  walkthroughUrl    String?   // video walkthrough (Loom etc.)
  extraContributors Json?     // [{ name, role? }] contributors without app accounts (legacy: string[])
  createdById       String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  approvedAt        DateTime?

  track       Track?              @relation(fields: [trackId], references: [id])
  createdBy   User?               @relation("ProjectCreator", fields: [createdById], references: [id])
  assignments ProjectAssignment[]
  interests   ProjectInterest[]

  @@index([status])
  @@map("projects")
}

// One "request to join" per member per project; leads/admins resolve these in-app.
model ProjectInterest {
  id            String    @id @default(cuid())
  projectId     String
  userId        String
  note          String?   // optional pitch from the member
  status        String    @default("pending") // pending | accepted | declined
  respondedById String?   // moderator who accepted/declined (audit stamp; no FK by design)
  respondedAt   DateTime? // when it was resolved; null while pending
  createdAt     DateTime  @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@unique([projectId, userId])
  @@index([status])
  @@map("project_interests")
}

// ─── Assignment (Homework) ──────────────────────────────────────────────────

model Assignment {
  id          String    @id @default(cuid())
  title       String
  description String    // Markdown instructions
  conceptId   String?   // Optional tie to a concept
  dueDate     DateTime?
  createdById String
  createdAt   DateTime  @default(now())

  concept     Concept?             @relation(fields: [conceptId], references: [id])
  createdBy   User                 @relation("AssignmentCreator", fields: [createdById], references: [id])
  submissions HomeworkSubmission[]

  @@map("assignments")
}

// ─── Formal Quiz System ─────────────────────────────────────────────────────

model FormalQuiz {
  id          String    @id @default(cuid())
  title       String
  description String?
  createdById String
  timeLimit   Int?      // Minutes, null = no limit
  availableAt DateTime? // When recruits can start
  dueDate     DateTime? // Deadline
  status      String    @default("draft") // draft | active | closed
  createdAt   DateTime  @default(now())

  createdBy  User                @relation("FormalQuizCreator", fields: [createdById], references: [id])
  questions  FormalQuizQuestion[]
  attempts   FormalQuizAttempt[]

  @@map("formal_quizzes")
}

model FormalQuizQuestion {
  id           String @id @default(cuid())
  formalQuizId String
  questionId   String
  sortOrder    Int

  formalQuiz FormalQuiz @relation(fields: [formalQuizId], references: [id], onDelete: Cascade)
  question   Question   @relation(fields: [questionId], references: [id])

  @@unique([formalQuizId, questionId])
  @@map("formal_quiz_questions")
}

model FormalQuizAttempt {
  id           String    @id @default(cuid())
  userId       String
  formalQuizId String
  score        Float?    // Calculated on submit (MC only)
  startedAt    DateTime  @default(now())
  submittedAt  DateTime?

  user       User              @relation(fields: [userId], references: [id])
  formalQuiz FormalQuiz        @relation(fields: [formalQuizId], references: [id])
  answers    FormalQuizAnswer[]

  @@unique([userId, formalQuizId]) // One attempt per recruit per quiz
  @@map("formal_quiz_attempts")
}

model FormalQuizAnswer {
  id         String   @id @default(cuid())
  attemptId  String
  questionId String
  selected   String?  // The text they chose (MC) or typed (SA)
  isCorrect  Boolean? // Auto-graded for MC, null for SA until admin grades
  gradedAt   DateTime?
  llmScore       String?  // "correct" | "partial" | "incorrect" — null for MC
  llmReasoning   String?  // LLM explanation of grade
  llmGradedAt    DateTime?

  attempt  FormalQuizAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question Question          @relation(fields: [questionId], references: [id])

  @@unique([attemptId, questionId])
  @@map("formal_quiz_answers")
}

// ─── Calendar (synced from SharePoint TCO Master Calendar) ──────────────────

model ScheduleEvent {
  id            String    @id @default(cuid())
  weekNumber    Int
  weekStart     DateTime  // Monday 00:00 of that week
  weekEnd       DateTime  // Sunday 23:59 of that week
  dayOfWeek     Int       // 0=Mon, 1=Tue, 2=Wed, 3=Thu, 4=Fri, 5=Homework column
  date          DateTime  // resolved actual date
  title         String
  description   String?
  startTime     String?   // "17:00"
  endTime       String?   // "20:00"
  location      String?   // Dream Lab, Willow Room, Lillis 132, etc.
  type          String    // TECH_TEAM | CAPITAL_TEAM | EVENTS | MEDIA_TEAM | EXEC | NON_MANDATORY | GENERAL
  category      String    @default("OTHER") // CLASS | MEETING | WORKSHOP | HOMEWORK | DEADLINE | OTHER
  topics        Json?     // string[] of sub-topics shown in expander (null if single event)
  relatedConceptSlugs Json? // string[] of Concept.slug the LLM picked for pre-session review
  sourceRowKey  String    @unique // e.g. "w4-tue-0" — stable upsert key
  syncedAt      DateTime  @default(now())

  @@index([date])
  @@index([weekNumber])
  @@map("schedule_events")
}

// ─── Feedback ───────────────────────────────────────────────────────────────

model Feedback {
  id          String    @id @default(cuid())
  userId      String
  content     String
  imagePath   String?   // Path inside the "feedback-images" Supabase bucket
  pageContext String?   // e.g. "/dashboard" — page the recruit was on
  status      String    @default("new") // new | read | resolved
  createdAt   DateTime  @default(now())
  resolvedAt  DateTime?

  user User @relation(fields: [userId], references: [id])

  @@index([status])
  @@index([createdAt])
  @@map("feedback")
}

// ─── LLM normalization cache ────────────────────────────────────────────────
// One row per weekday cell; LLM only re-runs when the cell's contentHash changes.

model ScheduleCellCache {
  cellKey     String   @id              // "w4-tue" (weekNumber + dayCode)
  contentHash String                    // SHA256 of raw parsed lines
  normalized  Json                      // normalized events: [{ title, description, topics, type, startTime, endTime }]
  updatedAt   DateTime @updatedAt

  @@map("schedule_cell_cache")
}

// ─── "This Week in Tech" digest (weekly cron + admin review-before-publish) ─

model DigestEdition {
  id          String    @id @default(cuid())
  weekOf      DateTime  @unique           // Monday 00:00 UTC of the digest week
  headline    String
  items       Json                        // [{ title, summary, whyItMatters, url, sourceDomain, resources: [{ title, url, type, sourceDomain }] }] — all URLs verified (200) before persist
  bigPicture  String?                     // "The big picture" closer: 1-2 paragraphs synthesizing the week (\n\n-separated)
  watchFor    String?                     // "What to watch": one concrete upcoming thing from the stories
  quiz        Json?                       // 3-4 self-check MC questions: [{ question, options: [{text, isCorrect}x4], explanation }]
  contentHash String                      // SHA256 of normalized headline+items; identical regenerate skips the write
  status      String    @default("draft") // draft | published — cron never publishes
  generatedAt DateTime  @default(now())
  publishedAt DateTime?
  searchesUsed Int?                       // observability: web searches the generating run used
  durationMs   Int?                       // observability: wall-clock of the generating run

  @@index([status])
  @@map("digest_editions")
}

// ─── Trend Tracker ("pulse of tech" bubble field + briefs) ──────────────────
// Seeded static-first from docs/research/trend-map-research.json as drafts; a
// daily cron (Phase 4) refreshes them via web search using the inline
// contentHash skip + curatedAt lock. Nothing student-facing until published.
// Trends are GLOBAL (categorized AI/Tech/Capital), not Track-scoped.

model Trend {
  id              String        @id @default(cuid())
  slug            String        @unique // kebab-case; upsert key + URL
  name            String
  category        String        // "AI" | "Tech" | "Capital"
  whatItIs        String        // plain-language explainer
  whatsHappening  String        // "what's happening now (mid-2026)"
  momentum        Int           @default(50) // 0-100, drives bubble size
  momentumLabel   String        @default("accelerating") // emerging|accelerating|mainstreaming|cooling
  direction       String        @default("heating") // heating|cooling -> solid|dashed ring
  themes          String[]      @default([]) // plain-language facet tags; display-only, replaces the momentumLabel stage in the UI (see docs/plans/complete/TREND_TRACKER_REDESIGN_PLAN.md section 3)
  relatedConcepts Json?         // [{ label, slug? }] - slug links to /concepts/[slug]
  sources         Json?         // string[] backing URLs
  perspectives    Json?         // { shape, intro, stances:[{label,who,summary,body,sources}], leans } - detail-page accordion; null = no section (see docs/plans/complete/PERSPECTIVES_PLAN.md)
  confidence      String        @default("high")
  status          String        @default("draft") // draft | published (publish gate)
  contentHash     String?       // SHA-256 for cron skip (inline, like DigestEdition)
  curatedAt       DateTime?     // set on any admin edit -> cron skips this row
  syncedAt        DateTime      @default(now()) // staleness banner if > 36h
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  updates         TrendUpdate[]

  @@index([status])
  @@index([category])
  @@map("trends")
}

model TrendUpdate {
  id           String   @id @default(cuid())
  trendId      String
  headline     String
  whyItMatters String
  sourceUrl    String?
  sourceDomain String?
  date         DateTime
  createdAt    DateTime @default(now())

  trend Trend @relation(fields: [trendId], references: [id], onDelete: Cascade)

  @@index([trendId])
  @@index([date])
  @@map("trend_updates")
}

// ─── Benchmarks ("The Standings" / State of the Models) ─────────────────────
// An editorial literacy surface for the AI benchmarks people argue about. STATUS
// (a trust tier), not the score, is the hero: per our own verified research almost
// every benchmark number is contested, dated, self-reported, or saturated. Leaders
// are stored inline as Json (mirroring DigestEdition/Trend, not a second table) so
// the future weekly cron (PR2) can reuse the inline contentHash + draft-gate shape.
// Seeded as drafts from docs/research/benchmarks-*.json; nothing student-facing
// until published. See docs/plans/ongoing/BENCHMARKS_PLAN.md.

model Benchmark {
  id               String   @id @default(cuid())
  slug             String   @unique          // kebab-case; upsert key + /benchmarks/[slug]
  name             String                     // "GPQA Diamond"
  domain           String                     // Reasoning | Coding | Math | Multimodal | Human preference | Agents
  scoreType        String                     // Accuracy | Elo | Pass rate (never compare an Elo to a %)
  trust            String                     // REQUIRED trust tier: live | near_ceiling | contested | dated
  nearTie          Boolean  @default(false)   // author-set; orthogonal to trust (drives the "ranks tied" note)
  caveat           String                     // the four-word list-row caveat ("dropped by OpenAI 2026")

  whatItMeasures   String                     // first sentence is the bus-stop lead; the rest fills the WHAT IT MEASURES beat
  exampleTask      String?
  whyCare          String
  scoring          String
  calibration      String?                    // "chance 25%, experts ~81%, prior SOTA X"
  watchOut         String
  watchOutUrl      String?

  leaders          Json                       // [{ rank, model, lab, score(verbatim), baselineGloss, asOfDate, sourceUrl, selfReported, disputed }]
  leaderboardUrl   String?
  boardLastUpdated DateTime?
  honestEmpty      Boolean  @default(false)   // true => "no reliable current leaderboard" + single dated anchor
  datedAnchor      String?                    // the single dated anchor shown in the honest-empty state
  needsRecheck     Boolean  @default(false)

  relatedConcepts  Json?                       // [{ label, slug? }] -> /concepts/[slug]
  sources          Json?                       // string[]
  useCases         Json?                       // string[] of UseCase slugs this benchmark backs (evidence strip + "also central to X")

  status           String   @default("draft")  // publish gate: draft | published (mirrors Trend.status)
  contentHash      String?                       // SHA-256 for the PR2 cron skip (inline, like Trend)
  curatedAt        DateTime?                      // set on admin edit -> PR2 cron skips this row
  syncedAt         DateTime @default(now())       // PR2 staleness banner
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([status])
  @@index([trust])
  @@map("benchmarks")
}

// ─── Use cases ("By Task, with Receipts") ───────────────────────────────────
// The second door at /benchmarks: a task-first explorer plus a per-use-case
// "decision walk" page where the spine is how-to-choose guidance and every
// honest pick is a welded ScoreStamp citing exactly one benchmark, one date,
// one caveat. Mirrors Benchmark's draft-gate + inline-Json shape so it inherits
// the publish path, the @@index([status]) visibility rule, the DraftChip, and
// the seed dash-validation for free. Picks AUTHOR the (slug, rank) + label +
// caveat; the score/lab/date/flags RESOLVE from the cited Benchmark.leaders at
// render, so a pick can never drift from the board it cites.
// Seeded as drafts from prisma/seed-data/use-cases.ts. See
// docs/plans/ongoing/BENCHMARKS_USE_CASES_BUILD_PLAN.md.

model UseCase {
  id                      String   @id @default(cuid())
  slug                    String   @unique           // kebab-case; upsert key + /benchmarks/use/[slug]
  name                    String                      // "Factual accuracy: not making things up"
  audienceLine            String                      // one-line student gloss (explorer + page lead)
  taskLead                String                      // the bold bus-stop framing sentence
  bottomLine              String                      // the dated bottom-line callout copy (authored, trust-gated)
  bottomLineBenchmarkSlug String?                     // the ONE board the bottom line + rail date bind to (null when honestEmpty)
  evidenceLine            String                      // "read mainly through SimpleQA, with HLE as a cross-check"
  yardsticks              Json                        // [{ benchmarkSlug, trustGloss }] ordered (the tests that matter)
  picks                   Json                        // [PickSeed] authored honest picks
  howToChoose             Json                        // [{ goal, benchmarkSlug?, guidance, noCleanAnswer?, reason? }]
  judgeCriteria           Json?                       // string[]; the honest-empty "judge it yourself on these two things"
  watchOut                String
  watchOutUrl             String?
  relatedConcepts         Json?                       // [{ label, slug? }] reuse the validated shape
  honestEmpty             Boolean  @default(false)    // AUTHORED: no backing board has a usable live leader; drives explorer grouping
  datedAnchor             String?                     // the single anchor shown when honestEmpty (present this FIRST)
  gapReason               String?                     // why no trustworthy board exists (shown after the anchor); required when honestEmpty
  order                   Int      @default(0)        // editorial sort within a group
  status                  String   @default("draft")  // publish gate, mirrors Benchmark
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@index([status])
  @@map("use_cases")
}
