# ── AISA Atlas Environment Variables ──────────────────────────
#
# Copy this file to .env and fill in the values:
#   cp .env.example .env

# Database connection string
# For local development with SQLite:
DATABASE_URL="file:./dev.db"

# For production (Supabase, Neon, or other PostgreSQL):
# DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# ── Supabase (for auth + storage) ─────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://<project>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<anon key>"

# Service-role key is used server-side only (feedback image uploads).
# Copy from Supabase → Project settings → API → service_role key.
# NEVER expose this to the client.
SUPABASE_SERVICE_ROLE_KEY="<service role key>"

# ── Notes ─────────────────────────────────────────────────────
# - SQLite is used for local dev. The database file lives at prisma/dev.db
# - To seed the database: npx tsx prisma/seed.ts
# - To view the database: npx prisma studio
# - For production, switch to PostgreSQL (Supabase or Neon recommended)
#   and update the provider in prisma/schema.prisma from "sqlite" to "postgresql"
